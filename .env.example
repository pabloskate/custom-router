# ─────────────────────────────────────────────────────────────────────────────
# .env.example
#
# Copy to .env.local for local development.
# In production, set these as Cloudflare Worker secrets / bindings.
#
# Legend:
#   [REQUIRED] — returns 500 errors without this
#   [OPTIONAL] — sensible default is used when omitted
# ─────────────────────────────────────────────────────────────────────────────

# [REQUIRED for BYOK persistence] Encrypts user-provided upstream API keys at rest.
# BYOK routes fail closed when this is missing.
BYOK_ENCRYPTION_SECRET=

# ── Admin ─────────────────────────────────────────────────────────────────────

# [REQUIRED for admin endpoints] Authenticates privileged routes:
#   POST /api/v1/admin/verify
#   GET/PUT /api/v1/router/config  (system-wide config)
# Pass as:  Authorization: Bearer <value>
#       or: X-Admin-Secret: <value>
ADMIN_SECRET=change-me-in-production

# ── Router ────────────────────────────────────────────────────────────────────

# [OPTIONAL] LLM used to make routing decisions (the "classifier").
# Default: gpt-oss-120b:nitro  (see src/lib/constants.ts → CLASSIFIER.DEFAULT_MODEL)
# Must be a valid OpenRouter model ID.
ROUTER_CLASSIFIER_MODEL=

# ── Registration ─────────────────────────────────────────────────────────────

# [OPTIONAL] Controls who can create accounts on this instance.
#   "open"   — anyone can sign up (original behavior)
#   "closed" — no new signups (first user is always allowed for initial setup)
#   "invite" — signup requires a valid invite code from an existing user
# Default: closed
REGISTRATION_MODE=closed

# ── Session cookies ───────────────────────────────────────────────────────────

# [OPTIONAL] Force Secure flag on session cookies.
# "true" | "false" — defaults to "true" when NODE_ENV=production.
SESSION_COOKIE_SECURE=false

# ── Password reset email delivery ────────────────────────────────────────────

# [OPTIONAL] Resend API key used to email password reset links.
# If omitted, password reset requests still succeed but only return a preview
# reset link in non-production environments.
RESEND_API_KEY=

# [OPTIONAL] Sender used for password reset emails, for example:
# PASSWORD_RESET_FROM_EMAIL=CustomRouter <noreply@example.com>
PASSWORD_RESET_FROM_EMAIL=

# [REQUIRED when password reset email is enabled] Trusted app URL used to
# build password reset links (prevents Host header injection), for example:
# PASSWORD_RESET_BASE_URL=https://custom-router.example.com
# If omitted, password reset emails are not sent.
PASSWORD_RESET_BASE_URL=

# ── Cloudflare bindings (injected automatically in production) ────────────────
# ROUTER_DB and ROUTER_KV are D1 / KV bindings set in wrangler.toml.
# For local dev, initOpenNextCloudflareForDev provides local D1/KV emulation
# and shares state with `npm run db:seed` (both use apps/web/wrangler.toml).
# Run `npm run db:seed` before first `npm run dev`; otherwise login returns 500.
